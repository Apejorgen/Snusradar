:root {
  --bg: #0f1012;
  --bg2: #181a1e;
  --bg3: #22252c;
  --bg4: #2a2d35;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.13);
  --border3: rgba(255,255,255,0.2);
  --text: #f0efe8;
  --text2: #9a9890;
  --text3: #5a5856;
  --green: #5DCAA5;
  --green-dark: #0F6E56;
  --green-bg: rgba(93,202,165,0.1);
  --green-bg2: rgba(93,202,165,0.18);
  --amber: #EF9F27;
  --amber-bg: rgba(239,159,39,0.1);
  --red: #E24B4A;
  --red-bg: rgba(226,75,74,0.1);
  --blue: #378ADD;
  --blue-bg: rgba(55,138,221,0.1);
  --radius: 12px;
  --radius-sm: 8px;
  --radius-xs: 6px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  overflow: hidden;
}

#app { height: 100%; display: flex; flex-direction: column; }

/* ── AUTH SCREEN ── */
.auth-screen {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}
.auth-screen::before {
  content: '';
  position: absolute;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(93,202,165,0.06) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}
.auth-box {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: 16px;
  padding: 40px;
  width: 380px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  position: relative;
  z-index: 1;
}
.auth-logo {
  font-family: 'Syne', sans-serif;
  font-size: 28px;
  font-weight: 800;
  letter-spacing: -0.5px;
  text-align: center;
  margin-bottom: 4px;
}
.auth-logo span { color: var(--green); }
.auth-tagline {
  text-align: center;
  font-size: 13px;
  color: var(--text3);
  margin-top: -14px;
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.5px;
}
.auth-tabs {
  display: flex;
  background: var(--bg3);
  border-radius: var(--radius-sm);
  padding: 3px;
  gap: 3px;
}
.auth-tab {
  flex: 1; padding: 8px;
  border-radius: var(--radius-xs);
  border: none; background: none;
  color: var(--text3); font-size: 13px;
  cursor: pointer; font-family: 'DM Sans', sans-serif;
  transition: all 0.15s;
}
.auth-tab.active { background: var(--bg4); color: var(--text); }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label { font-size: 11px; font-family: 'DM Mono', monospace; color: var(--text3); letter-spacing: 0.8px; text-transform: uppercase; }
.form-input {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius-sm); padding: 10px 14px;
  color: var(--text); font-size: 14px; font-family: 'DM Sans', sans-serif;
  outline: none; transition: border-color 0.15s; width: 100%;
}
.form-input:focus { border-color: var(--green); }
.form-input::placeholder { color: var(--text3); }
.auth-btn {
  width: 100%; padding: 12px;
  border-radius: var(--radius-sm); border: none;
  background: var(--green); color: #052e1f;
  font-size: 14px; font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer; transition: opacity 0.15s;
}
.auth-btn:hover { opacity: 0.88; }
.auth-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.auth-error {
  color: var(--red); font-size: 12px;
  padding: 8px 12px; background: var(--red-bg);
  border-radius: var(--radius-xs); border: 1px solid rgba(226,75,74,0.2);
  display: none;
}

/* ── APP SHELL ── */
.app-shell { height: 100%; display: flex; flex-direction: column; }

/* ── TOPBAR ── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--bg); flex-shrink: 0; z-index: 100;
}
.logo {
  font-family: 'Syne', sans-serif; font-size: 18px;
  font-weight: 800; letter-spacing: -0.5px; color: var(--text);
}
.logo span { color: var(--green); }
.nav-tabs {
  display: flex; gap: 3px;
  background: var(--bg2); border-radius: var(--radius-sm); padding: 3px;
}
.nav-tab {
  padding: 6px 16px; border-radius: var(--radius-xs);
  font-size: 13px; cursor: pointer; color: var(--text3);
  border: none; background: none; transition: all 0.12s;
  font-family: 'DM Sans', sans-serif;
}
.nav-tab.active { background: var(--bg3); color: var(--text); }
.topbar-right { display: flex; align-items: center; gap: 10px; }
.ping-notif {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--green-bg); border: 1px solid var(--green);
  display: none; align-items: center; justify-content: center;
  font-size: 12px; color: var(--green); cursor: pointer;
  animation: pulse 1.5s infinite;
}
.ping-notif.visible { display: flex; }
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(93,202,165,0.4); }
  50% { box-shadow: 0 0 0 6px rgba(93,202,165,0); }
}
.me-avatar {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--green-dark); color: var(--green);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 500; cursor: pointer;
  border: 1.5px solid var(--border2); transition: border-color 0.15s;
  font-family: 'DM Mono', monospace;
}
.me-avatar:hover { border-color: var(--green); }

/* ── VIEWS ── */
.view { display: none; flex: 1; overflow: hidden; }
.view.active { display: flex; }

/* ── MAP VIEW ── */
#mapView { position: relative; }
.map-container { flex: 1; position: relative; }
#googleMap { width: 100%; height: 100%; }

/* SIDEBAR */
.sidebar {
  width: 290px; flex-shrink: 0;
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  background: var(--bg); overflow: hidden; z-index: 10;
}
.sidebar-header { padding: 14px 14px 10px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
.sidebar-label {
  font-size: 10px; font-family: 'DM Mono', monospace;
  letter-spacing: 1.2px; text-transform: uppercase;
  color: var(--text3); margin-bottom: 8px;
}
.search-input {
  width: 100%; background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius-sm); padding: 7px 12px;
  color: var(--text); font-size: 13px; font-family: 'DM Sans', sans-serif;
  outline: none; transition: border-color 0.15s;
}
.search-input:focus { border-color: var(--border2); }
.search-input::placeholder { color: var(--text3); }
.friend-list { overflow-y: auto; flex: 1; padding: 6px; }
.friend-list::-webkit-scrollbar { width: 3px; }
.friend-list::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 3px; }

.friend-item {
  padding: 10px; border-radius: var(--radius-sm);
  cursor: pointer; transition: background 0.1s;
  border: 1px solid transparent; margin-bottom: 3px;
  display: flex; align-items: center; gap: 10px;
}
.friend-item:hover { background: var(--bg2); }
.friend-item.selected { background: var(--bg2); border-color: var(--border); }
.f-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 500; flex-shrink: 0;
  position: relative; font-family: 'DM Mono', monospace;
}
.f-dot {
  position: absolute; bottom: 1px; right: 1px;
  width: 9px; height: 9px; border-radius: 50%;
  border: 2px solid var(--bg);
}
.f-dot.available { background: var(--green); }
.f-dot.maybe { background: var(--amber); }
.f-dot.empty { background: var(--red); }
.f-dot.offline { background: var(--text3); }
.f-info { flex: 1; min-width: 0; }
.f-name { font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.f-sub { font-size: 11px; color: var(--text2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 1px; }
.f-badge {
  font-size: 10px; font-family: 'DM Mono', monospace;
  padding: 3px 7px; border-radius: 20px; flex-shrink: 0;
}
.f-badge.available { background: var(--green-bg); color: var(--green); }
.f-badge.maybe { background: var(--amber-bg); color: var(--amber); }
.f-badge.empty { background: var(--red-bg); color: var(--red); }
.f-badge.offline { background: var(--bg3); color: var(--text3); }

.add-friend-btn {
  margin: 8px; padding: 10px;
  border-radius: var(--radius-sm); border: 1px dashed var(--border2);
  background: none; color: var(--text3); font-size: 13px;
  cursor: pointer; font-family: 'DM Sans', sans-serif;
  transition: all 0.15s; flex-shrink: 0;
}
.add-friend-btn:hover { border-color: var(--green); color: var(--green); background: var(--green-bg); }

/* DETAIL PANEL */
.detail-panel {
  position: absolute; top: 14px; right: 14px;
  width: 256px; background: var(--bg);
  border: 1px solid var(--border2); border-radius: var(--radius);
  padding: 16px; z-index: 20;
  display: none; flex-direction: column; gap: 14px;
}
.detail-panel.open { display: flex; }
.dp-close {
  position: absolute; top: 10px; right: 10px;
  width: 22px; height: 22px; border-radius: 50%;
  border: none; background: var(--bg3); color: var(--text2);
  font-size: 12px; cursor: pointer; display: flex;
  align-items: center; justify-content: center; font-family: monospace;
  transition: color 0.12s;
}
.dp-close:hover { color: var(--text); }
.dp-top { display: flex; align-items: center; gap: 10px; }
.dp-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 500; flex-shrink: 0;
  font-family: 'DM Mono', monospace;
}
.dp-name { font-size: 15px; font-weight: 500; }
.dp-loc { font-size: 11px; color: var(--text2); margin-top: 2px; font-family: 'DM Mono', monospace; }
.dp-status {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 12px; border-radius: var(--radius-sm);
  font-size: 13px; font-weight: 500;
}
.dp-status.available { background: var(--green-bg); color: var(--green); }
.dp-status.maybe { background: var(--amber-bg); color: var(--amber); }
.dp-status.empty { background: var(--red-bg); color: var(--red); }
.dp-status.offline { background: var(--bg3); color: var(--text3); }
.dp-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
.dp-section-label {
  font-size: 10px; font-family: 'DM Mono', monospace;
  letter-spacing: 1px; text-transform: uppercase; color: var(--text3); margin-bottom: 7px;
}
.brand-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.brand-tag {
  font-size: 11px; padding: 3px 9px; border-radius: 20px;
  border: 1px solid var(--border2); color: var(--text2);
  background: var(--bg2); font-family: 'DM Mono', monospace;
}
.stock-bar { height: 5px; background: var(--bg3); border-radius: 3px; overflow: hidden; margin-top: 5px; }
.stock-fill { height: 100%; border-radius: 3px; transition: width 0.4s; }
.stock-fill.available { background: var(--green); }
.stock-fill.maybe { background: var(--amber); }
.stock-fill.empty { background: var(--red); }
.stock-meta { display: flex; justify-content: space-between; font-size: 11px; color: var(--text2); margin-top: 3px; font-family: 'DM Mono', monospace; }
.ping-btn {
  width: 100%; padding: 9px; border-radius: var(--radius-sm);
  border: 1px solid var(--border2); background: var(--bg2);
  color: var(--text); font-size: 13px; font-weight: 500;
  cursor: pointer; font-family: 'DM Sans', sans-serif;
  transition: all 0.15s; display: flex; align-items: center;
  justify-content: center; gap: 6px;
}
.ping-btn:hover { background: var(--green-bg); border-color: var(--green); color: var(--green); }
.ping-btn.sent { background: var(--green-bg); border-color: var(--green); color: var(--green); }
.ping-dot-el { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }

/* ── FRIENDS PAGE ── */
#friendsView { flex-direction: column; overflow-y: auto; padding: 24px; }
.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-shrink: 0; }
.page-title { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; }
.icon-btn {
  padding: 8px 16px; border-radius: var(--radius-sm);
  border: 1px solid var(--border2); background: none;
  color: var(--text2); font-size: 13px; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: all 0.15s;
}
.icon-btn:hover { border-color: var(--green); color: var(--green); background: var(--green-bg); }
.friends-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 12px;
}
.friend-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 16px;
  transition: border-color 0.15s;
}
.friend-card:hover { border-color: var(--border2); }
.fc-top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.fc-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 500; flex-shrink: 0;
  position: relative; font-family: 'DM Mono', monospace;
}
.fc-name { font-size: 14px; font-weight: 500; }
.fc-email { font-size: 11px; color: var(--text2); margin-top: 2px; font-family: 'DM Mono', monospace; }
.fc-divider { height: 1px; background: var(--border); margin-bottom: 12px; }
.fc-brands { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 12px; }
.fc-brand {
  font-size: 11px; padding: 3px 8px; border-radius: 20px;
  border: 1px solid var(--border); color: var(--text2);
  font-family: 'DM Mono', monospace;
}
.remove-btn {
  width: 100%; padding: 7px; border-radius: var(--radius-sm);
  border: 1px solid var(--border); background: none;
  color: var(--text3); font-size: 12px; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: all 0.12s;
}
.remove-btn:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }
.empty-state {
  text-align: center; padding: 60px 20px;
  color: var(--text3); font-size: 13px; line-height: 2;
  font-family: 'DM Mono', monospace;
}

/* ── PROFILE PAGE ── */
#profileView { flex-direction: column; overflow-y: auto; padding: 24px; }
.profile-form { max-width: 440px; display: flex; flex-direction: column; gap: 20px; }
.avatar-row { display: flex; align-items: center; gap: 16px; }
.profile-big-avatar {
  width: 64px; height: 64px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 500; flex-shrink: 0;
  font-family: 'DM Mono', monospace;
}
.color-dots { display: flex; gap: 8px; flex-wrap: wrap; }
.color-dot {
  width: 24px; height: 24px; border-radius: 50%;
  cursor: pointer; border: 2px solid transparent;
  transition: transform 0.12s, border-color 0.12s;
}
.color-dot:hover { transform: scale(1.15); }
.color-dot.selected { border-color: var(--text); }

.brands-field {
  display: flex; flex-wrap: wrap; gap: 6px; padding: 10px;
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius-sm); min-height: 48px;
  cursor: text; transition: border-color 0.15s;
}
.brands-field:focus-within { border-color: var(--green); }
.chip {
  display: flex; align-items: center; gap: 5px;
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: 20px; padding: 3px 10px;
  font-size: 12px; font-family: 'DM Mono', monospace; color: var(--text2);
}
.chip-x { cursor: pointer; color: var(--text3); background: none; border: none; font-size: 14px; line-height: 1; transition: color 0.1s; }
.chip-x:hover { color: var(--red); }
.chip-input {
  flex: 1; min-width: 80px; background: none; border: none;
  outline: none; color: var(--text); font-size: 13px; font-family: 'DM Sans', sans-serif;
}
.chip-input::placeholder { color: var(--text3); }

.avail-row { display: flex; gap: 8px; }
.avail-btn {
  flex: 1; padding: 9px 6px; border-radius: var(--radius-sm);
  border: 1px solid var(--border); background: var(--bg2);
  color: var(--text2); font-size: 12px; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: all 0.12s; text-align: center;
}
.avail-btn:hover { border-color: var(--border2); color: var(--text); }
.avail-btn.sel-available { background: var(--green-bg); border-color: var(--green); color: var(--green); }
.avail-btn.sel-maybe { background: var(--amber-bg); border-color: var(--amber); color: var(--amber); }
.avail-btn.sel-empty { background: var(--red-bg); border-color: var(--red); color: var(--red); }

.stock-slider-wrap { display: flex; flex-direction: column; gap: 6px; }
.stock-slider {
  -webkit-appearance: none; width: 100%; height: 4px;
  border-radius: 2px; background: var(--bg3); outline: none;
}
.stock-slider::-webkit-slider-thumb {
  -webkit-appearance: none; width: 16px; height: 16px;
  border-radius: 50%; background: var(--green); cursor: pointer;
  border: 2px solid var(--bg2);
}
.slider-label { display: flex; justify-content: space-between; font-size: 11px; color: var(--text2); font-family: 'DM Mono', monospace; }

.save-row { display: flex; align-items: center; gap: 12px; }
.save-btn {
  padding: 10px 24px; border-radius: var(--radius-sm);
  border: none; background: var(--green); color: #052e1f;
  font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif;
  cursor: pointer; transition: opacity 0.15s;
}
.save-btn:hover { opacity: 0.85; }
.saved-msg { font-size: 12px; color: var(--green); font-family: 'DM Mono', monospace; opacity: 0; transition: opacity 0.3s; }
.saved-msg.show { opacity: 1; }
.logout-btn {
  padding: 10px 18px; border-radius: var(--radius-sm);
  border: 1px solid var(--border); background: none;
  color: var(--text3); font-size: 13px; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: all 0.15s;
  margin-top: 12px; align-self: flex-start;
}
.logout-btn:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }

/* ── MODALS ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.65);
  z-index: 500; display: none; align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--bg2); border: 1px solid var(--border2);
  border-radius: var(--radius); padding: 24px;
  width: 360px; display: flex; flex-direction: column; gap: 16px;
}
.modal-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; }
.modal-sub { font-size: 13px; color: var(--text2); margin-top: -10px; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
.btn-cancel {
  padding: 8px 16px; border-radius: var(--radius-sm);
  border: 1px solid var(--border); background: none;
  color: var(--text2); font-size: 13px; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: all 0.12s;
}
.btn-cancel:hover { border-color: var(--border2); color: var(--text); }
.btn-primary {
  padding: 8px 18px; border-radius: var(--radius-sm);
  border: none; background: var(--green); color: #052e1f;
  font-size: 13px; font-weight: 500; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: opacity 0.15s;
}
.btn-primary:hover { opacity: 0.85; }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
.modal-error {
  font-size: 12px; color: var(--red); background: var(--red-bg);
  padding: 8px 12px; border-radius: var(--radius-xs);
  border: 1px solid rgba(226,75,74,0.2); display: none;
}
.found-user {
  display: none; padding: 12px; background: var(--bg3);
  border-radius: var(--radius-sm); border: 1px solid var(--border2);
  gap: 10px; align-items: center;
}
.found-user.show { display: flex; }
.found-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 500; background: var(--green-dark); color: var(--green);
  font-family: 'DM Mono', monospace; flex-shrink: 0;
}
.found-name { font-size: 14px; font-weight: 500; }
.found-email { font-size: 11px; color: var(--text2); font-family: 'DM Mono', monospace; }

/* PING TOAST */
.ping-toast {
  position: fixed; bottom: 24px; right: 24px;
  background: var(--bg2); border: 1px solid var(--green);
  border-radius: var(--radius); padding: 14px 18px;
  display: flex; align-items: center; gap: 12px;
  z-index: 1000; transform: translateY(80px); opacity: 0;
  transition: all 0.3s ease; pointer-events: none;
}
.ping-toast.show { transform: translateY(0); opacity: 1; }
.ping-toast-icon { font-size: 18px; }
.ping-toast-text { font-size: 13px; }
.ping-toast-name { color: var(--green); font-weight: 500; }

/* SHARE LINK */
.share-box {
  display: flex; gap: 8px; align-items: center;
  background: var(--bg3); border-radius: var(--radius-sm);
  padding: 8px 12px; border: 1px solid var(--border);
}
.share-url { flex: 1; font-size: 12px; font-family: 'DM Mono', monospace; color: var(--text2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.copy-btn {
  padding: 5px 12px; border-radius: var(--radius-xs);
  border: 1px solid var(--border2); background: none;
  color: var(--text2); font-size: 12px; cursor: pointer;
  font-family: 'DM Sans', sans-serif; transition: all 0.12s; flex-shrink: 0;
}
.copy-btn:hover { border-color: var(--green); color: var(--green); }
.copy-btn.copied { border-color: var(--green); color: var(--green); background: var(--green-bg); }

/* LOADING */
.loading-screen {
  position: fixed; inset: 0; background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  z-index: 9999; flex-direction: column; gap: 16px;
}
.loading-logo { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; }
.loading-logo span { color: var(--green); }
.loading-spinner {
  width: 20px; height: 20px; border-radius: 50%;
  border: 2px solid var(--border2); border-top-color: var(--green);
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.gps-btn {
  padding: 8px 14px; border-radius: var(--radius-sm);
  border: 1px solid var(--border2); background: var(--bg2);
  color: var(--text2); font-size: 12px; cursor: pointer;
  font-family: 'DM Mono', monospace; transition: all 0.12s;
  display: flex; align-items: center; gap: 6px;
}
.gps-btn:hover { border-color: var(--green); color: var(--green); }
.gps-btn.active { border-color: var(--green); color: var(--green); background: var(--green-bg); }
.gps-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
